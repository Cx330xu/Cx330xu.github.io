---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogArticle from '../../../components/BlogArticle.astro';
import { filterByLocale, sortByDate, getSlugFromId } from '../../../utils/content';

export async function getStaticPaths() {
  const locale = 'zh';
  const posts = sortByDate(
    filterByLocale(
      await getCollection('blog', ({ data }) => !data.draft),
      locale,
    ),
  );

  return posts.map((post, index) => ({
    params: { slug: getSlugFromId(post.id) },
    props: {
      post,
      prevPost: posts[index + 1],
      nextPost: posts[index - 1],
    },
  }));
}

const locale = 'zh' as const;
const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout locale={locale} title={post.data.title} description={post.data.description} image={post.data.cover}>
  <BlogArticle locale={locale} post={post} prevPost={prevPost} nextPost={nextPost} Content={Content} />
</BaseLayout>
