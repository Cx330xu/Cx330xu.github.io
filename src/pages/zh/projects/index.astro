---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import ProjectFilter from '../../../components/ProjectFilter.astro';
import EmptyState from '../../../components/EmptyState.astro';
import FadeIn from '../../../components/FadeIn.astro';
import { t } from '../../../i18n/ui';
import { filterByLocale, sortByDate } from '../../../utils/content';

const locale = 'zh' as const;
const ui = t(locale);

const all = sortByDate(
  filterByLocale(
    await getCollection('projects', ({ data }) => !data.draft),
    locale,
  ),
);
---

<BaseLayout locale={locale} title={ui.projects.title} description={ui.projects.subtitle}>
  <header class="mb-8">
    <h1 class="text-3xl font-bold mb-2">{ui.projects.title}</h1>
    <p class="text-[var(--color-muted)]">{ui.projects.subtitle}</p>
  </header>

  <ProjectFilter locale={locale} />

  {
    all.length === 0 ? (
      <EmptyState locale={locale} message={ui.projects.empty} hint={ui.projects.emptyHint} />
    ) : (
      <div class="grid gap-4 sm:grid-cols-2">
        {
          all.map((project) => (
            <FadeIn>
              <div
                data-project-card
                data-featured={project.data.featured}
                data-stacks={project.data.stack.join(',').toLowerCase()}
              >
                <ProjectCard project={project} locale={locale} />
              </div>
            </FadeIn>
          ))
        }
      </div>
    )
  }
</BaseLayout>
