---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Giscus from '../../../components/Giscus.astro';
import ProjectMetaBar from '../../../components/ProjectMetaBar.astro';
import ProjectTechDoc from '../../../components/ProjectTechDoc.astro';

export async function getStaticPaths() {
  const items = await getCollection('projects', ({ id, data }) => id.startsWith('zh/') && !data.draft);
  return items.map((project) => ({
    params: { slug: project.id.replace(/^zh\//, '') },
    props: { project },
  }));
}

const locale = 'zh' as const;
const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout locale={locale} title={project.data.title} description={project.data.description}>
  <article>
    <header class="mb-6">
      <h1 class="text-3xl font-bold mb-3">{project.data.title}</h1>
      <p class="text-[var(--color-muted)] mb-4">{project.data.description}</p>
    </header>
    <ProjectMetaBar project={project} locale={locale} />
    <div class="prose">
      <Content />
    </div>
    <ProjectTechDoc locale={locale} project={project} />
    <Giscus locale={locale} />
  </article>
</BaseLayout>
