---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Avatar from '../../components/Avatar.astro';
import AboutChannels from '../../components/AboutChannels.astro';
import ContactLinks from '../../components/ContactLinks.astro';
import Timeline from '../../components/Timeline.astro';
import { profile } from '../../data/site';
import { t } from '../../i18n/ui';

const locale = 'en' as const;
const ui = t(locale);
const page = await getEntry('pages', 'en/about')!;
const { Content } = await render(page);
---

<BaseLayout locale={locale} title={ui.about.title} description={page.data.description}>
  <div class="flex flex-col sm:flex-row gap-8 items-start mb-8">
    <Avatar size="lg" />
    <div>
      <h1 class="text-3xl font-bold mb-2">{profile.name}</h1>
      <p class="text-lg text-[var(--color-muted)] mb-4">{profile.title[locale]}</p>
      <ContactLinks locale={locale} />
    </div>
  </div>
  <AboutChannels locale={locale} />
  <Timeline locale={locale} />
  <div class="prose">
    <Content />
  </div>
</BaseLayout>
