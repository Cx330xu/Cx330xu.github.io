---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/ui';

const locale = 'en' as const;
const ui = t(locale);
const page = await getEntry('pages', 'en/now')!;
const { Content } = await render(page);
---

<BaseLayout locale={locale} title={ui.now.title} description={page.data.description}>
  <header class="mb-8">
    <h1 class="text-3xl font-bold mb-2">{ui.now.title}</h1>
    <p class="text-[var(--color-muted)]">{ui.now.subtitle}</p>
  </header>
  <div class="prose">
    <Content />
  </div>
</BaseLayout>
