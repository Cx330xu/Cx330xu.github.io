---
import { getCollection } from 'astro:content';
import { csdn, profile, heroSkills } from '../data/site';
import Chip from './Chip.astro';
import { t, type Locale } from '../i18n/ui';
import { filterByLocale, sortByDate, collectTags, slugifyTag } from '../utils/content';
import { shouldShowGithubActivity, getRepoStarsMap } from '../utils/githubContributions';
import Avatar from './Avatar.astro';
import ContactLinks from './ContactLinks.astro';
import HeroAside from './HeroAside.astro';
import HeroSnapshotMobile from './HeroSnapshotMobile.astro';
import SocialProofBar from './SocialProofBar.astro';
import TypingTagline from './TypingTagline.astro';
import ProjectCard from './ProjectCard.astro';
import FeaturedProjectHero from './FeaturedProjectHero.astro';
import GithubActivity from './GithubActivity.astro';
import PostCard from './PostCard.astro';
import NoteItem from './NoteItem.astro';
import TagCloud from './TagCloud.astro';
import FadeIn from './FadeIn.astro';
import WallpaperToggle from './WallpaperToggle.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = t(locale);
const showGithubActivity = await shouldShowGithubActivity();

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const allNotes = await getCollection('notes', ({ data }) => !data.draft);

const projects = sortByDate(filterByLocale(allProjects, locale));
const posts = sortByDate(filterByLocale(allPosts, locale));
const notes = sortByDate(filterByLocale(allNotes, locale));

const featured = projects.filter((p) => p.data.featured).slice(0, 3);
const sortedPosts = [...posts].sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.date.getTime() - a.data.date.getTime();
});
const latestPosts = sortedPosts.slice(0, 3);
const latestNotes = notes.slice(0, 5);
const allTags = collectTags([...posts, ...notes, ...projects]);
const useSingleColumn = latestPosts.length < 2;

const githubUrls = projects.map((p) => p.data.github);
const repoStars = await getRepoStarsMap(githubUrls);

const featuredGridClass =
  featured.length === 2
    ? 'grid gap-4 sm:grid-cols-2'
    : 'grid gap-4 sm:grid-cols-2 lg:grid-cols-3';

const csdnArchivePath = `/${locale}/blog/csdn-archive/`;
const latestPostSlug = latestPosts[0]?.id.replace(/^(zh|en)\//, '');
---

<section class="mb-16">
  <div class="grid lg:grid-cols-[minmax(0,1fr)_280px] gap-8 items-start">
    <div class="flex flex-col sm:flex-row items-start gap-5 sm:gap-6 min-w-0">
      <Avatar size="lg" />
      <div class="min-w-0 flex-1 pt-0.5 sm:pt-1">
        <h1 class="text-2xl sm:text-3xl font-bold tracking-tight mb-1">{profile.name}</h1>
        <p class="text-xl sm:text-2xl font-semibold text-[var(--color-primary)] mb-1.5">{profile.title[locale]}</p>
        <p class="text-sm text-[var(--color-muted)] max-w-xl mb-2 leading-relaxed">
          {profile.valueProposition[locale]}
        </p>
        <div class="flex items-center gap-2 mb-3">
          <span class="h-px flex-1 bg-[var(--color-border)]" aria-hidden="true"></span>
          <span class="text-[10px] uppercase tracking-[0.15em] text-[var(--color-muted)]/60">{ui.home.skillsLabel}</span>
          <span class="h-px flex-1 bg-[var(--color-border)]" aria-hidden="true"></span>
        </div>
        <div class="flex flex-wrap gap-2 mb-3">
          {heroSkills.map((skill) => (
            <Chip
              label={skill.label}
              href={`/${locale}/tags/${slugifyTag(skill.id)}/`}
              prefixHash={false}
              variant="primary"
            />
          ))}
        </div>
        <TypingTagline locale={locale} />
        <SocialProofBar
          locale={locale}
          projectCount={projects.length}
          latestPostDate={latestPosts[0]?.data.date}
        />
        <div class="mb-5 pt-0.5">
          <ContactLinks locale={locale} />
        </div>
        <div class="flex flex-wrap gap-3">
          <a
            href={`/${locale}/projects/`}
            class="px-5 py-2.5 rounded-lg bg-[var(--color-primary)] text-white text-sm font-medium hover:opacity-90 transition-opacity"
          >
            {ui.home.viewProjects}
          </a>
          <a
            href={`/${locale}/blog/`}
            class="px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-sm font-medium hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
          >
            {ui.home.readBlog}
          </a>
        </div>
      </div>
    </div>
    <HeroAside
      locale={locale}
      projectCount={projects.length}
      postCount={posts.length}
      noteCount={notes.length}
      latestPost={latestPosts[0]}
      showGithubLink={!showGithubActivity}
    />
  </div>
  <HeroSnapshotMobile
    locale={locale}
    projectCount={projects.length}
    postCount={posts.length}
    noteCount={notes.length}
  />
  <div class="lg:hidden flex justify-center mt-3">
    <WallpaperToggle locale={locale} variant="full" />
  </div>
</section>

{
  featured.length > 0 && (
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold">{ui.home.featuredProjects}</h2>
        <a href={`/${locale}/projects/`} class="text-sm text-[var(--color-primary)] hover:underline">
          {ui.home.allProjects} →
        </a>
      </div>
      {
        featured.length === 1 ? (
          <FeaturedProjectHero
            project={featured[0]}
            locale={locale}
            starCount={repoStars.get(featured[0].data.github)}
          />
        ) : (
          <div class={featuredGridClass}>
            {featured.map((project) => (
              <FadeIn>
                <ProjectCard
                  project={project}
                  locale={locale}
                  starCount={repoStars.get(project.data.github)}
                />
              </FadeIn>
            ))}
          </div>
        )
      }
    </section>
  )
}

<section class:list={['mb-16', useSingleColumn ? 'space-y-10' : 'grid gap-10 lg:grid-cols-2']}>
  <div>
    <div class="flex items-center justify-between gap-3 mb-4">
      <h2 class="text-xl font-semibold">{ui.home.latestPosts}</h2>
      <a href={`/${locale}/blog/`} class="text-sm text-[var(--color-primary)] hover:underline shrink-0">{ui.home.readBlog} →</a>
    </div>
    <div class="space-y-3">
      {latestPosts.map((post) => (
        <FadeIn>
          <PostCard post={post} locale={locale} variant="compact" />
        </FadeIn>
      ))}
    </div>
    <a href={csdnArchivePath} class="inline-block mt-5 text-sm text-[var(--color-primary)] hover:underline">
      {ui.home.csdnArchiveTeaser.replace('{count}', String(csdn.postCount))}
    </a>
  </div>
  <div>
    <div class="flex items-center justify-between gap-3 mb-4">
      <div class="flex items-center gap-2 min-w-0">
        <h2 class="text-xl font-semibold">{ui.home.latestNotes}</h2>
        <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] shrink-0">
          {ui.home.recentlyUpdated}
        </span>
      </div>
      <a href={`/${locale}/notes/`} class="text-sm text-[var(--color-primary)] hover:underline shrink-0">{ui.home.viewAllNotes} →</a>
    </div>
    <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-4">
      {latestNotes.map((note) => (
        <FadeIn>
          <NoteItem note={note} locale={locale} showRelative />
        </FadeIn>
      ))}
    </div>
  </div>
</section>

{
  allTags.length >= 5 ? (
    <section class="mb-16">
      <h2 class="text-xl font-semibold mb-4">{ui.home.exploreTags}</h2>
      <TagCloud tags={allTags.slice(0, 12)} locale={locale} />
      <div class="flex gap-4 mt-4 text-sm">
        <a href={`/${locale}/tags/`} class="text-[var(--color-primary)] hover:underline">{ui.home.allTags} →</a>
        <a href={`/${locale}/categories/`} class="text-[var(--color-primary)] hover:underline">{ui.home.allCategories} →</a>
      </div>
    </section>
  ) : null
}

{
  showGithubActivity ? <GithubActivity locale={locale} /> : null
}

<section class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-8 text-center">
  <h2 class="text-xl font-semibold mb-2">{ui.home.ctaTitle}</h2>
  <p class="text-sm text-[var(--color-muted)] mb-5 max-w-md mx-auto">
    {locale === 'zh'
      ? '对 AI Agent / RAG 方向感兴趣？欢迎通过邮箱联系，我会提供详细项目说明。'
      : 'Interested in AI Agent / RAG? Reach out via email — I am happy to share detailed project context.'}
  </p>
  <div class="flex flex-col items-center gap-3">
    {
      latestPostSlug && (
        <a
          href={`/${locale}/blog/${latestPostSlug}/`}
          class="px-5 py-2.5 rounded-lg bg-[var(--color-primary)] text-white text-sm font-medium hover:opacity-90 transition-opacity"
        >
          {ui.home.ctaReadLatest}
        </a>
      )
    }
    <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm">
      <a href={`/${locale}/projects/`} class="text-[var(--color-primary)] hover:underline">
        {ui.home.ctaOrBrowseProjects}
      </a>
      <a href={`mailto:${profile.email}?subject=${locale === 'zh' ? '[合作/面试邀约]' : '[Collaboration/Interview]'} Cx330xu`} class="inline-flex items-center gap-1 text-[var(--color-primary)] font-medium hover:underline">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {profile.email}
      </a>
    </div>
  </div>
</section>
