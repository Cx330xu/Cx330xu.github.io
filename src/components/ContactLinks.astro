---
import { csdn, profile } from '../data/site';
import type { Locale } from '../i18n/ui';
import EmailLink from './EmailLink.astro';
import ResumeDownload from './ResumeDownload.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
  <a
    href={profile.github}
    target="_blank"
    rel="noopener noreferrer"
    class="text-[var(--color-primary)] font-medium hover:underline"
  >
    GitHub
  </a>
  <span class="text-[var(--color-border)] hidden sm:inline" aria-hidden="true">·</span>
  <a
    href={csdn.url}
    target="_blank"
    rel="noopener noreferrer"
    class="text-[var(--color-primary)] font-medium hover:underline"
  >
    CSDN
  </a>
  <span class="text-[var(--color-border)] hidden sm:inline" aria-hidden="true">·</span>
  <a
    href={profile.gitee}
    target="_blank"
    rel="noopener noreferrer"
    class="text-[var(--color-primary)] font-medium hover:underline"
  >
    Gitee
  </a>
  <span class="text-[var(--color-border)] hidden sm:inline" aria-hidden="true">·</span>
  {
    profile.linkedin && (
      <>
        <a
          href={profile.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[var(--color-primary)] font-medium hover:underline"
        >
          LinkedIn
        </a>
        <span class="text-[var(--color-border)] hidden sm:inline" aria-hidden="true">·</span>
      </>
    )
  }
  <EmailLink locale={locale} variant="inline" />
  <span class="text-[var(--color-border)] hidden sm:inline" aria-hidden="true">·</span>
  <ResumeDownload locale={locale} variant="inline" />
</div>
