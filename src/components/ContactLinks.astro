---
import { csdn, profile } from '../data/site';
import type { Locale } from '../i18n/ui';
import EmailLink from './EmailLink.astro';

interface Props {
  locale: Locale;
}

const { locale: _locale } = Astro.props;
---

<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
  <a
    href={profile.github}
    target="_blank"
    rel="noopener noreferrer"
    class="text-[var(--color-primary)] hover:underline"
  >
    GitHub
  </a>
  <a
    href={csdn.url}
    target="_blank"
    rel="noopener noreferrer"
    class="text-[var(--color-primary)] hover:underline"
  >
    CSDN
  </a>
  <EmailLink locale={_locale} variant="inline" />
</div>
