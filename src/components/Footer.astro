---
import { csdn, profile } from '../data/site';
import { t, type Locale } from '../i18n/ui';
import EmailLink from './EmailLink.astro';
import Newsletter from './Newsletter.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = t(locale);
const year = new Date().getFullYear();
const analyticsEnabled = import.meta.env.PROD && Boolean(import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN?.trim());
---

<footer class="relative z-[1] border-t border-[var(--color-border)] mt-auto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--color-muted)]">
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a href={profile.github} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-primary)] transition-colors">
        GitHub
      </a>
      <a href={csdn.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-primary)] transition-colors">
        CSDN
      </a>
      <a href={profile.gitee} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-primary)] transition-colors">
        Gitee
      </a>
      <EmailLink locale={locale} variant="inline" showIcon={false} />
      <a href={`/${locale}/archives/`} class="hover:text-[var(--color-primary)] transition-colors">
        {ui.nav.archives}
      </a>
      <a href={`/${locale}/now/`} class="hover:text-[var(--color-primary)] transition-colors">
        {ui.nav.now}
      </a>
      <a href={`/${locale}/search/`} class="hover:text-[var(--color-primary)] transition-colors">
        {ui.nav.search}
      </a>
      <a href={`/${locale}/rss.xml`} class="hover:text-[var(--color-primary)] transition-colors">
        RSS
      </a>
    </div>
    <p class="text-center sm:text-right">
      © {year} {profile.name} · {ui.footer.builtWith}
      {analyticsEnabled && (
        <>
          <span class="mx-1" aria-hidden="true">·</span>
          <span class="text-xs">{ui.footer.analyticsNote}</span>
        </>
      )}
    </p>
    <div class="mt-6 pt-6 border-t border-[var(--color-border)] max-w-md">
      <Newsletter locale={locale} />
    </div>
  </div>
</footer>
