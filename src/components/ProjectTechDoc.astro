---
import { projectTechDocs } from '../data/project-tech-docs';

interface Props {
  locale: string;
  /** Project translationKey — used to look up tech doc data */
  slug?: string;
}

const { locale = 'zh', slug } = Astro.props;

const panels = [
  { key: 'techChallenges',   title: { zh: '技术难点', en: 'Technical Challenges' }, summary: { zh: '为什么做这个项目？解决了什么独特问题？', en: 'Why this project? What unique problem does it solve?' } },
  { key: 'techDecisions',    title: { zh: '方案对比与决策', en: 'Solution Comparison & Decisions' }, summary: { zh: '关键技术选型的权衡与理由', en: 'Trade-offs and rationale behind key technical choices' } },
  { key: 'techArchitecture', title: { zh: '架构设计', en: 'Architecture Design' }, summary: { zh: '系统架构、数据流与核心设计模式', en: 'System architecture, data flow, and core design patterns' } },
];

function getContent(panelKey: string): string | null {
  if (!slug) return null;
  const docs = projectTechDocs as Record<string, any>;
  // 优先按 slug 精确匹配，兜底遍历所有条目（处理传参异常）
  let projectData = docs[slug];
  if (!projectData) {
    for (const key of Object.keys(docs)) {
      const v = docs[key];
      if (v && v[locale] && (v[locale][panelKey] || '').length > 200) { projectData = v; break; }
    }
  }
  if (!projectData) return null;
  const localeData = projectData[locale];
  if (!localeData) return null;
  const content = localeData[panelKey];
  if (!content || typeof content !== 'string' || content.trim().length === 0) return null;
  const lower = content.toLowerCase();
  if (['正在撰写', 'being written', '占位', 'placeholder'].some(p => lower.includes(p))) return null;
  return content;
}
---

<style>
  .tech-doc-panel {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    margin-bottom: 0.75rem;
    overflow: hidden;
    background: var(--color-surface);
  }
  .tech-doc-panel summary {
    padding: 1rem 1.25rem;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    user-select: none;
    color: var(--color-text);
    transition: color 0.15s;
  }
  .tech-doc-panel summary:hover { color: var(--color-primary); }
  .tech-doc-panel summary::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--color-muted);
    transition: transform 0.2s;
    width: 1.5rem;
    text-align: center;
    flex-shrink: 0;
  }
  .tech-doc-panel[open] summary::after {
    content: '\2212';
    transform: rotate(180deg);
  }
  .tech-doc-panel .panel-body {
    padding: 0 1.25rem 1.25rem;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-muted);
  }
  .tech-doc-panel .panel-body :global(h3) { font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75em; }
  .tech-doc-panel .panel-body :global(p) { margin-bottom: 0.75em; }
  .tech-doc-panel .panel-body :global(strong) { color: var(--color-text); font-weight: 600; }
  .tech-doc-panel .panel-body :global(em) { color: var(--color-primary); font-style: normal; }
  .tech-doc-panel .panel-body :global(code) { background: rgba(128,128,128,0.15); padding: 0.15em 0.4em; border-radius: 4px; font-size: 0.88em; }
  .tech-doc-panel .panel-body :global(pre) { background: var(--color-surface-alt, rgba(0,0,0,0.3)); padding: 0.75rem 1rem; border-radius: 8px; overflow-x: auto; white-space: pre; font-family: 'Cascadia Code','Fira Code',monospace; font-size: 0.82em; line-height: 1.5; margin-bottom: 0.75em; }
  .tech-doc-summary-hint {
    font-size: 0.8rem; font-weight: 400; color: var(--color-muted); opacity: 0.6;
    text-align: right; flex: 1; margin-left: 0.5rem;
  }
</style>

<div class="mt-8 pt-6 border-t border-[var(--color-border)]">
  <h2 class="text-lg font-semibold mb-3">
    {locale === 'zh' ? '技术文档' : 'Technical Documentation'}
  </h2>
  {panels.map((panel) => {
    const content = getContent(panel.key);
    const filled = !!content;
    return (
      <details class="tech-doc-panel group" open={filled}>
        <summary>
          <span>{panel.title[locale as keyof typeof panel.title]}</span>
          <span class="tech-doc-summary-hint">{panel.summary[locale as keyof typeof panel.summary]}</span>
        </summary>
        <div class="panel-body">
          {filled ? (
            <div set:html={content!} />
          ) : (
            <>
              <p><em>{locale === 'zh'
                ? `该项目的详细${panel.title.zh}正在撰写中。`
                : `Detailed ${panel.title.en.toLowerCase()} documentation for this project is being written.`
              }</em></p>
              <p>{locale === 'zh' ? '在实际部署版本中，此处将展示具体的技术描述、架构决策与设计模式说明。' : 'When populated, this section will showcase specific technical descriptions, architectural decisions, and design patterns.'}</p>
            </>
          )}
        </div>
      </details>
    );
  })}
  <p class="text-xs text-[var(--color-muted)]/50 mt-4">
    {locale === 'zh'
      ? '💡 提示：点击每个面板展开详细内容。此组件采用 HTML5 <details> 元素，无需 JavaScript。'
      : '💡 Tip: Click each panel to expand. Uses native HTML5 <details> elements — no JavaScript needed.'}
  </p>
</div>
