---
// Fetch Bing daily wallpapers at build time (no CORS in Node.js).
// We fetch the last 8 days so users can cycle through them.
interface BingImage {
  url: string;
  copyright?: string;
}
let wallpapers: BingImage[] = [];
try {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 8000);
  const res = await fetch(
    'https://www.bing.com/HPImageArchive.aspx?format=js&idx=0&n=8&mkt=zh-CN',
    { signal: controller.signal },
  );
  clearTimeout(timeout);
  if (res.ok) {
    const data: any = await res.json();
    wallpapers = (data.images ?? []).map((img: any) => ({
      url: 'https://www.bing.com' + (img.url ?? ''),
      copyright: img.copyright ?? '',
    }));
  }
} catch {
  // Silently keep empty — wallpaper will be unavailable
}
const wallpapersJson = JSON.stringify(wallpapers);
---

{/* Hidden element carries pre-fetched wallpaper URLs to the client script */}
<span id="bing-wallpaper-data" data-wallpapers={wallpapersJson} aria-hidden="true" hidden></span>

<script>
  const WALLPAPER_DATA = document.getElementById('bing-wallpaper-data');
  const PREBUILT: { url: string; copyright?: string }[] = (() => {
    try {
      return JSON.parse(WALLPAPER_DATA?.dataset.wallpapers ?? '[]');
    } catch {
      return [];
    }
  })();

  const STORAGE_KEY = 'wallpaper-mode';
  const INDEX_KEY = 'wallpaper-index';

  let currentUrl: string | null = null;

  function getActiveIndex(): number {
    const stored = localStorage.getItem(INDEX_KEY);
    const idx = stored ? parseInt(stored, 10) : 0;
    return Number.isFinite(idx) && idx >= 0 && idx < PREBUILT.length ? idx : 0;
  }

  function setActiveIndex(idx: number) {
    localStorage.setItem(INDEX_KEY, String(idx));
  }

  function applyWallpaper(url: string | null) {
    if (url) {
      currentUrl = url;
      const img = new Image();
      img.onload = () => {
        if (currentUrl !== url) return;
        document.body.style.setProperty('--wallpaper-bg', `url(${encodeURI(url)})`);
        document.body.classList.add('wallpaper-active');
      };
      img.src = url;
      document.body.style.setProperty('--wallpaper-bg', `url(${encodeURI(url)})`);
      document.body.classList.add('wallpaper-active');
    } else {
      currentUrl = null;
      document.body.style.removeProperty('--wallpaper-bg');
      document.body.classList.remove('wallpaper-active');
    }
  }

  function removeWallpaper() {
    currentUrl = null;
    document.body.style.removeProperty('--wallpaper-bg');
    document.body.classList.remove('wallpaper-active');
  }

  function getWallpaperUrl(): string | null {
    if (PREBUILT.length === 0) return null;
    const idx = getActiveIndex();
    return PREBUILT[idx]?.url ?? PREBUILT[0]?.url ?? null;
  }

  async function setMode(active: boolean) {
    if (active) {
      const url = getWallpaperUrl();
      applyWallpaper(url);
    } else {
      removeWallpaper();
    }
  }

  // Public API exposed on window for other components
  function cycleWallpaper(): string | null {
    if (PREBUILT.length <= 1) return null;
    const nextIdx = (getActiveIndex() + 1) % PREBUILT.length;
    setActiveIndex(nextIdx);
    const url = PREBUILT[nextIdx]?.url ?? null;
    if (url) applyWallpaper(url);
    // Dispatch event so toggles can update their UI
    window.dispatchEvent(new CustomEvent('wallpaper-cycled', { detail: { index: nextIdx, url } }));
    return url;
  }

  (window as any).__wallpaperCycle = cycleWallpaper;
  (window as any).__wallpaperCount = PREBUILT.length;

  // Init
  const stored = localStorage.getItem(STORAGE_KEY);
  // Default to gallery mode on first visit
  if (stored === null) {
    localStorage.setItem(STORAGE_KEY, 'gallery');
  }
  if ((stored ?? 'gallery') === 'gallery') {
    setMode(true);
  }

  // Listen for toggle events from WallpaperToggle
  window.addEventListener('wallpaper-change', (e: Event) => {
    const { active } = (e as CustomEvent).detail;
    setMode(active);
  });

  // Listen for cycle requests
  window.addEventListener('wallpaper-cycle', () => {
    cycleWallpaper();
  });
</script>
