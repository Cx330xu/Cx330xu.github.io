---
// Build-time: fetch 8 Bing wallpapers as fallback (no CORS in Node.js).
interface BingImage { url: string; copyright?: string; }
let prebuiltWallpapers: BingImage[] = [];
try {
  const ctl = new AbortController();
  const t = setTimeout(() => ctl.abort(), 8000);
  const res = await fetch('https://www.bing.com/HPImageArchive.aspx?format=js&idx=0&n=8&mkt=zh-CN', { signal: ctl.signal });
  clearTimeout(t);
  if (res.ok) {
    const data: any = await res.json();
    prebuiltWallpapers = (data.images ?? []).map((img: any) => ({ url: 'https://www.bing.com' + (img.url ?? ''), copyright: img.copyright ?? '' }));
  }
} catch { /* keep empty */ }
const prebuiltJson = JSON.stringify(prebuiltWallpapers);
---

<span id="bing-wallpaper-data" data-prebuilt={prebuiltJson} aria-hidden="true" hidden></span>

<script>
  const BING_API = 'https://www.bing.com/HPImageArchive.aspx?format=js&idx=0&n=8&mkt=zh-CN';
  // Multiple CORS proxies to try (ordered by reliability)
  const CORS_PROXIES = [
    'https://corsproxy.io/?',
    'https://api.allorigins.win/raw?url=',
    'https://api.codetabs.com/v1/proxy?quest=',
  ];

  const dataEl = document.getElementById('bing-wallpaper-data');
  const PREBUILT: { url: string; copyright?: string }[] = (() => {
    try { return JSON.parse(dataEl?.dataset.prebuilt ?? '[]'); } catch { return []; }
  })();

  const STORAGE_KEY = 'wallpaper-mode';
  const INDEX_KEY  = 'wallpaper-index';
  const CACHE_KEY  = 'bing-wallpapers';
  const CACHE_DATE = 'bing-wallpaper-date';

  let currentUrl: string | null = null;

  function todayStr() { return new Date().toISOString().slice(0, 10); }
  function loadCache(): { url: string; copyright?: string }[] | null {
    if (localStorage.getItem(CACHE_DATE) !== todayStr()) return null;
    try { const r = localStorage.getItem(CACHE_KEY); return r ? JSON.parse(r) : null; } catch { return null; }
  }
  function saveCache(list: { url: string; copyright?: string }[]) {
    localStorage.setItem(CACHE_KEY, JSON.stringify(list));
    localStorage.setItem(CACHE_DATE, todayStr());
  }
  function getIdx(): number {
    const s = localStorage.getItem(INDEX_KEY); const i = s ? parseInt(s, 10) : 0;
    const list = loadCache() ?? PREBUILT;
    return Number.isFinite(i) && i >= 0 && i < list.length ? i : 0;
  }
  function setIdx(i: number) { localStorage.setItem(INDEX_KEY, String(i)); }
  function activeList() { return loadCache() ?? PREBUILT; }
  function getUrl(): string | null { const l = activeList(); if (!l.length) return null; const i = getIdx(); return l[i]?.url ?? l[0]?.url ?? null; }

  function apply(url: string | null) {
    if (url) {
      currentUrl = url;
      // Downsample on mobile/slow-connection for performance
      const finalUrl = maybeDownsample(url);
      const img = new Image();
      img.onload = () => { if (currentUrl === url) { document.body.style.setProperty('--wallpaper-bg', `url(${encodeURI(finalUrl)})`); document.body.classList.add('wallpaper-active'); } };
      img.src = finalUrl;
      document.body.style.setProperty('--wallpaper-bg', `url(${encodeURI(finalUrl)})`);
      document.body.classList.add('wallpaper-active');
    } else { currentUrl = null; document.body.style.removeProperty('--wallpaper-bg'); document.body.classList.remove('wallpaper-active'); }
  }
  function remove() { currentUrl = null; document.body.style.removeProperty('--wallpaper-bg'); document.body.classList.remove('wallpaper-active'); }

  // Replace Bing 1920×1080 with smaller variant for mobile / save-data
  function maybeDownsample(u: string): string {
    try {
      const slow = (navigator as any).connection?.saveData === true;
      const mobile = window.matchMedia('(max-width: 768px)').matches;
      if (!slow && !mobile) return u;
    } catch { return u; }
    // Bing uses _1920x1080 in the filename; use 1024×576 for mobile, 640×360 for save-data
    try {
      const slow = (navigator as any).connection?.saveData === true;
      return u.replace(/_(1920|1366)x(1080|768)/, slow ? '_640x360' : '_1024x576');
    } catch { return u.replace(/_(1920|1366)x(1080|768)/, '_1024x576'); }
  }

  // ── runtime fetch (retry with exponential backoff) ──
  async function fetchFresh(retries = 2): Promise<{ url: string; copyright?: string }[] | null> {
    for (const proxy of [null, ...CORS_PROXIES]) {
      for (let attempt = 0; attempt <= retries; attempt++) {
        try {
          const ctl = new AbortController();
          const timeoutMs = proxy ? 10000 : 6000;
          const t = setTimeout(() => ctl.abort(), timeoutMs);
          const url = proxy ? proxy + encodeURIComponent(BING_API) : BING_API;
          const res = await fetch(url, { signal: ctl.signal });
          clearTimeout(t);
          if (res.ok) {
            const data = await res.json();
            const imgs = (data.images ?? []) as any[];
            if (imgs.length) return imgs.map((img: any) => ({ url: 'https://www.bing.com' + (img.url ?? ''), copyright: img.copyright ?? '' }));
          }
        } catch { /* try next attempt */ }
        // exponential backoff: 500ms, 1000ms, 2000ms...
        if (attempt < retries) await new Promise(r => setTimeout(r, 500 * Math.pow(2, attempt)));
      }
    }
    return null;
  }

  // ── public ──
  async function refresh(): Promise<boolean> {
    // Show spinner on all refresh buttons
    document.querySelectorAll('.wallpaper-refresh-btn').forEach(b => b.classList.add('animate-spin'));
    try {
      // Fetch fresh first → apply if successful (no flash-revert)
      const fresh = await fetchFresh();
      if (fresh && fresh.length) {
        saveCache(fresh); setIdx(0); apply(fresh[0].url);
        window.dispatchEvent(new CustomEvent('wallpaper-refreshed', { detail: { count: fresh.length } }));
        return true;
      }
      // All fetches failed → cycle to next prebuilt (always a visible change)
      const ok = cycle();
      if (ok) window.dispatchEvent(new CustomEvent('wallpaper-refresh-fallback', {}));
      return ok;
    } finally {
      document.querySelectorAll('.wallpaper-refresh-btn').forEach(b => b.classList.remove('animate-spin'));
    }
  }

  function cycle(): boolean {
    const list = activeList(); if (list.length <= 1) return false;
    const next = (getIdx() + 1) % list.length; setIdx(next);
    const url = list[next]?.url ?? null; if (url) apply(url);
    window.dispatchEvent(new CustomEvent('wallpaper-cycled', { detail: { index: next, url, total: list.length } }));
    return true;
  }

  (window as any).__wallpaperCycle   = cycle;
  (window as any).__wallpaperRefresh = refresh;
  (window as any).__wallpaperCount   = () => activeList().length;

  // ── init ──
  async function init() {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === null) localStorage.setItem(STORAGE_KEY, 'gallery');
    if ((stored ?? 'gallery') !== 'gallery') return;
    if (!loadCache()) { const fresh = await fetchFresh(); if (fresh && fresh.length) saveCache(fresh); }
    apply(getUrl());
  }
  init();

  window.addEventListener('wallpaper-change', (e: Event) => {
    const { active } = (e as CustomEvent).detail;
    active ? apply(getUrl()) : remove();
  });
  window.addEventListener('wallpaper-cycle', () => { cycle(); });
  window.addEventListener('wallpaper-refresh', async () => { await refresh(); });
</script>
