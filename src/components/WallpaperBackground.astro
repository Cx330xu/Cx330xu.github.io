<script>
  // Bing daily wallpaper — applied as body background when "gallery" mode is on.
  // Works with WallpaperToggle via localStorage + custom event.
  const BING_API = 'https://www.bing.com/HPImageArchive.aspx?format=js&idx=0&n=1&mkt=zh-CN';
  const STORAGE_KEY = 'wallpaper-mode';
  const CACHE_KEY = 'bing-wallpaper-url';
  const CACHE_DATE = 'bing-wallpaper-date';

  let currentUrl: string | null = null;

  async function fetchBingWallpaper(): Promise<string | null> {
    // check cache (same day)
    const today = new Date().toISOString().slice(0, 10);
    const cachedDate = localStorage.getItem(CACHE_DATE);
    const cachedUrl = localStorage.getItem(CACHE_KEY);
    if (cachedDate === today && cachedUrl) {
      return cachedUrl;
    }

    try {
      const res = await fetch(BING_API);
      if (!res.ok) return cachedUrl ?? null;
      const data = await res.json();
      const url = 'https://www.bing.com' + (data.images?.[0]?.url ?? '');
      if (!url || url === 'https://www.bing.com') return cachedUrl ?? null;
      localStorage.setItem(CACHE_KEY, url);
      localStorage.setItem(CACHE_DATE, today);
      return url;
    } catch {
      return cachedUrl ?? null;
    }
  }

  function applyWallpaper(url: string | null) {
    if (url) {
      currentUrl = url;
      // Preload image, then apply
      const img = new Image();
      img.onload = () => {
        if (currentUrl !== url) return; // stale
        document.body.style.setProperty('--wallpaper-bg', `url(${url})`);
        document.body.classList.add('wallpaper-active');
      };
      img.src = url;
      // also apply immediately as the image loads in background
      document.body.style.setProperty('--wallpaper-bg', `url(${url})`);
      document.body.classList.add('wallpaper-active');
    } else {
      currentUrl = null;
      document.body.style.removeProperty('--wallpaper-bg');
      document.body.classList.remove('wallpaper-active');
    }
  }

  function removeWallpaper() {
    currentUrl = null;
    document.body.style.removeProperty('--wallpaper-bg');
    document.body.classList.remove('wallpaper-active');
  }

  async function setMode(active: boolean) {
    if (active) {
      const url = await fetchBingWallpaper();
      applyWallpaper(url);
    } else {
      removeWallpaper();
    }
  }

  // init
  const stored = localStorage.getItem(STORAGE_KEY);
  if (stored === 'gallery') {
    setMode(true);
  }

  // listen for toggle changes
  window.addEventListener('wallpaper-change', (e: Event) => {
    const { active } = (e as CustomEvent).detail;
    setMode(active);
  });
</script>
