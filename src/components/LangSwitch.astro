---
import { getCollection } from 'astro:content';
import { resolveLocaleSwitch } from '../utils/localeSwitch';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;

const [blog, projects, notes] = await Promise.all([
  getCollection('blog', ({ data }) => !data.draft),
  getCollection('projects', ({ data }) => !data.draft),
  getCollection('notes', ({ data }) => !data.draft),
]);

const zhSwitch = resolveLocaleSwitch(currentPath, locale, 'zh', { blog, projects, notes });
const enSwitch = resolveLocaleSwitch(currentPath, locale, 'en', { blog, projects, notes });

const zhHref = locale === 'zh' ? currentPath : zhSwitch.href;
const enHref = locale === 'en' ? currentPath : enSwitch.href;
const zhFallback = locale !== 'zh' && zhSwitch.fallback;
const enFallback = locale !== 'en' && enSwitch.fallback;
---

<div class="flex items-center rounded-md border border-[var(--color-border)] text-xs overflow-hidden">
  <a
    href={zhHref}
    data-lang-fallback={zhFallback ? 'true' : 'false'}
    class:list={[
      'lang-switch-link px-2 py-1 transition-colors',
      locale === 'zh' ? 'bg-[var(--color-primary)] text-white font-medium' : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
    ]}
  >
    ZH
  </a>
  <a
    href={enHref}
    data-lang-fallback={enFallback ? 'true' : 'false'}
    class:list={[
      'lang-switch-link px-2 py-1 transition-colors',
      locale === 'en' ? 'bg-[var(--color-primary)] text-white font-medium' : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
    ]}
  >
    EN
  </a>
</div>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.lang-switch-link').forEach((link) => {
    link.addEventListener('click', () => {
      if (link.dataset.langFallback === 'true') {
        sessionStorage.setItem('lang-fallback', '1');
      } else {
        sessionStorage.removeItem('lang-fallback');
      }
    });
  });
</script>
