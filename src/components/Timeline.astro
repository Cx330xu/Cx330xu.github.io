---
import type { Locale } from '../i18n/ui';

interface Milestone {
  /** ISO date string (YYYY-MM) */
  date: string;
  title: Record<Locale, string>;
  description: Record<Locale, string>;
  /** Optional tag: 'work' | 'project' | 'learning' | 'milestone' */
  tag?: 'work' | 'project' | 'learning' | 'milestone';
}

const milestones: Milestone[] = [
  {
    date: '2024-06',
    title: { zh: '开始 LLM 工程探索', en: 'Started LLM Engineering' },
    description: {
      zh: '系统学习大语言模型 API 调用、Prompt Engineering 与基础 RAG 架构',
      en: 'Systematically studied LLM APIs, prompt engineering, and foundational RAG architecture',
    },
    tag: 'learning',
  },
  {
    date: '2024-10',
    title: { zh: 'CSDN 技术博客启动', en: 'Launched CSDN Tech Blog' },
    description: {
      zh: '开始在 CSDN 发布原创技术文章，涵盖 LLM、Python 工程等方向，累计 19+ 篇',
      en: 'Started publishing original technical articles on CSDN covering LLM, Python engineering — 19+ posts and counting',
    },
    tag: 'milestone',
  },
  {
    date: '2025-03',
    title: { zh: 'Prompt System 项目发布', en: 'Released Prompt System' },
    description: {
      zh: '设计并实现基于 FastAPI + Next.js 的提示词管理系统，支持 Docker 部署与团队协作',
      en: 'Designed and built a prompt management system with FastAPI + Next.js, with Docker support and team collaboration',
    },
    tag: 'project',
  },
  {
    date: '2025-09',
    title: { zh: '提示工程深度文章发布', en: 'Published Prompt Engineering Deep-Dive' },
    description: {
      zh: '撰写万字提示工程系统教程，涵盖 CoT、RAG、Agent 等核心技术，获 CSDN 推荐',
      en: 'Authored a 10k-word prompt engineering tutorial covering CoT, RAG, and Agent techniques',
    },
    tag: 'milestone',
  },
  {
    date: '2026-06',
    title: { zh: 'Personal Tech Hub 上线', en: 'Personal Tech Hub Launched' },
    description: {
      zh: '用 Astro 构建中英双语个人技术品牌站，整合项目展示、博客、笔记与 GitHub 活跃度',
      en: 'Built a bilingual personal tech brand site with Astro, integrating project showcases, blog, notes, and GitHub activity',
    },
    tag: 'project',
  },
];

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const tagColors: Record<string, string> = {
  work: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300',
  project: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300',
  learning: 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300',
  milestone: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300',
};

const tagLabels: Record<Locale, Record<string, string>> = {
  zh: { work: '工作', project: '项目', learning: '学习', milestone: '里程碑' },
  en: { work: 'Work', project: 'Project', learning: 'Learning', milestone: 'Milestone' },
};
---

<section class="not-prose mb-10">
  <h2 class="text-xl font-semibold mb-6">
    {locale === 'zh' ? '技术旅程' : 'Tech Journey'}
  </h2>
  <div class="relative pl-6 border-l-2 border-[var(--color-border)] space-y-6">
    {
      milestones.map((m) => (
        <div class="relative">
          {/* Timeline dot */}
          <div class="absolute -left-[25px] top-1 w-3 h-3 rounded-full border-2 border-[var(--color-primary)] bg-[var(--color-bg)]" />
          <div class="flex flex-wrap items-center gap-2 mb-1">
            <time datetime={m.date} class="text-xs font-mono text-[var(--color-muted)]">
              {m.date}
            </time>
            {
              m.tag && (
                <span class={`text-xs px-1.5 py-0.5 rounded-full font-medium ${tagColors[m.tag]}`}>
                  {tagLabels[locale][m.tag]}
                </span>
              )
            }
          </div>
          <h3 class="font-semibold text-base mb-1">{m.title[locale]}</h3>
          <p class="text-sm text-[var(--color-muted)] leading-relaxed">{m.description[locale]}</p>
        </div>
      ))
    }
  </div>
</section>
