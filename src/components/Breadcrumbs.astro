---
import { t, type Locale } from '../i18n/ui';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  locale: Locale;
  items: Crumb[];
}

const { locale, items } = Astro.props;
const ui = t(locale);
---

<nav aria-label="Breadcrumb" class="mb-6 text-sm text-[var(--color-muted)]">
  <ol class="flex flex-wrap items-center gap-1.5">
    <li>
      <a href={`/${locale}/`} class="hover:text-[var(--color-primary)] transition-colors">
        {ui.breadcrumb.home}
      </a>
    </li>
    {
      items.map((item, index) => (
        <li class="flex items-center gap-1.5">
          <span aria-hidden="true">/</span>
          {
            item.href && index < items.length - 1 ? (
              <a href={item.href} class="hover:text-[var(--color-primary)] transition-colors">
                {item.label}
              </a>
            ) : (
              <span class="text-[var(--color-text)]">{item.label}</span>
            )
          }
        </li>
      ))
    }
  </ol>
</nav>
