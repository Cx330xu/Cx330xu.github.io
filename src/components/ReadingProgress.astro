---
// A thin progress bar at the top of the viewport showing reading progress.
// Include in blog post and project detail pages.
---

<div
  id="reading-progress"
  class="fixed top-0 left-0 h-[3px] bg-[var(--color-primary)] z-[60] transition-[width] duration-100 ease-out"
  style="width: 0%"
  role="progressbar"
  aria-valuenow="0"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-label="Reading progress"
></div>

<script>
  function setupReadingProgress() {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;

    function update() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      if (docHeight <= 0) {
        bar.style.width = '0%';
        bar.setAttribute('aria-valuenow', '0');
        return;
      }
      const progress = Math.min(100, Math.round((scrollTop / docHeight) * 100));
      bar.style.width = `${progress}%`;
      bar.setAttribute('aria-valuenow', String(progress));
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  setupReadingProgress();
  document.addEventListener('astro:after-swap', setupReadingProgress);
</script>
