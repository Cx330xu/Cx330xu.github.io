---
import { t, type Locale } from '../i18n/ui';
import { getPagefindLanguage } from '../utils/content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = t(locale);
const pagefindLang = getPagefindLanguage(locale);
const base = `/${locale}`;
const quickTerms = ['docker', 'agent', 'rag', 'prompt'];
---

<header class="mb-6">
  <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
    <div>
      <h1 class="text-3xl font-bold mb-2">{ui.search.title}</h1>
      <p class="text-[var(--color-muted)]">{ui.search.subtitle}</p>
    </div>
    <span class="text-xs px-2.5 py-1 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-muted)] shrink-0">
      {ui.search.scopeBadge}
    </span>
  </div>
  <p class="text-sm text-[var(--color-muted)] leading-relaxed">{ui.search.tip}</p>
</header>

<nav class="mb-6 flex flex-wrap gap-2" aria-label={ui.search.browseLabel}>
  {
    [
      { href: `${base}/blog/`, label: ui.nav.blog },
      { href: `${base}/projects/`, label: ui.nav.projects },
      { href: `${base}/notes/`, label: ui.nav.notes },
      { href: `${base}/tags/`, label: ui.tags.title },
    ].map((link) => (
      <a
        href={link.href}
        class="text-xs px-3 py-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-muted)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
      >
        {link.label}
      </a>
    ))
  }
</nav>

<div class="mb-4">
  <p class="text-xs text-[var(--color-muted)] mb-2">{ui.search.tryLabel}</p>
  <div class="flex flex-wrap gap-2">
    {
      quickTerms.map((term) => (
        <button
          type="button"
          class="search-quick-term text-xs px-3 py-1 rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] hover:bg-[var(--color-primary)]/15 transition-colors"
          data-term={term}
        >
          {term}
        </button>
      ))
    }
  </div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<div id="search" class="pagefind-search"></div>

<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline define:vars={{ pagefindLang, placeholder: ui.search.placeholder, emptyText: ui.search.empty }}>
  function initSearch() {
    if (typeof PagefindUI === 'undefined') return;
    const el = document.getElementById('search');
    if (!el) return;
    el.innerHTML = '';
    new PagefindUI({
      element: '#search',
      bundlePath: '/pagefind/',
      showSubResults: true,
      excludeFilters: ['language'],
      filters: { language: pagefindLang },
      translations: {
        placeholder,
        zero_results: emptyText,
      },
    });

    window.setTimeout(() => {
      const input = el.querySelector('.pagefind-ui__search-input');
      if (!(input instanceof HTMLInputElement)) return;

      const params = new URLSearchParams(window.location.search);
      const q = params.get('q');
      if (q) {
        input.value = q;
        input.dispatchEvent(new Event('input', { bubbles: true }));
      } else {
        input.focus();
      }

      document.querySelectorAll('.search-quick-term').forEach((btn) => {
        if (btn.dataset.bound === 'true') return;
        btn.dataset.bound = 'true';
        btn.addEventListener('click', () => {
          const term = btn.dataset.term ?? '';
          input.value = term;
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.focus();
        });
      });
    }, 80);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
  document.addEventListener('astro:after-swap', initSearch);
</script>

<style is:global>
  .pagefind-search {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-primary);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-bg);
    --pagefind-ui-font: var(--font-sans);
  }

  .pagefind-search .pagefind-ui__form {
    margin-bottom: 1.25rem;
  }

  .pagefind-search .pagefind-ui__search-input {
    border-radius: 0.75rem;
    padding: 0.875rem 1rem;
    font-size: 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .pagefind-search .pagefind-ui__search-input:focus {
    outline: 2px solid color-mix(in srgb, var(--color-primary) 35%, transparent);
    outline-offset: 0;
    border-color: var(--color-primary);
  }

  .pagefind-search .pagefind-ui__result {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem 1.125rem;
    margin-bottom: 0.75rem;
    background: var(--color-surface);
    transition: border-color 0.2s;
  }

  .pagefind-search .pagefind-ui__result:hover {
    border-color: color-mix(in srgb, var(--color-primary) 45%, var(--color-border));
  }

  .pagefind-search .pagefind-ui__result-title {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.4;
  }

  .pagefind-search .pagefind-ui__result-excerpt {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin-top: 0.375rem;
  }

  .pagefind-search .pagefind-ui__result-tags {
    margin-top: 0.625rem;
    gap: 0.375rem;
  }

  .pagefind-search .pagefind-ui__result-tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: var(--color-bg);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
  }

  .pagefind-search mark {
    background: color-mix(in srgb, var(--color-primary) 22%, transparent);
    color: inherit;
    border-radius: 0.125rem;
    padding: 0 0.125rem;
  }

  .pagefind-search .pagefind-ui__message {
    color: var(--color-muted);
    font-size: 0.875rem;
    padding: 2rem 0;
    text-align: center;
  }
</style>
