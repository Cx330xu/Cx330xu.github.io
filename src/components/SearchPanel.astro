---
import { t, type Locale } from '../i18n/ui';
import { getPagefindLanguage } from '../utils/content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = t(locale);
const pagefindLang = getPagefindLanguage(locale);
const base = `/${locale}`;
const quickTerms = ['docker', 'agent', 'rag', 'prompt'];
const typeFilters = [
  { key: '', label: ui.search.typeAll },
  { key: 'blog', label: ui.search.types.blog },
  { key: 'project', label: ui.search.types.project },
  { key: 'note', label: ui.search.types.note },
] as const;
---

<header class="mb-6">
  <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
    <div>
      <h1 class="text-3xl font-bold mb-2">{ui.search.title}</h1>
      <p class="text-[var(--color-muted)]">{ui.search.subtitle}</p>
    </div>
    <span class="text-xs px-2.5 py-1 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-muted)] shrink-0">
      {ui.search.scopeBadge}
    </span>
  </div>
  <p class="text-sm text-[var(--color-muted)] leading-relaxed">{ui.search.tip}</p>
  <p class="text-xs text-[var(--color-muted)] mt-2 opacity-80">{ui.search.shortcutHint}</p>
</header>

<nav class="mb-6 flex flex-wrap gap-2" aria-label={ui.search.browseLabel}>
  {
    [
      { href: `${base}/blog/`, label: ui.nav.blog },
      { href: `${base}/projects/`, label: ui.nav.projects },
      { href: `${base}/notes/`, label: ui.nav.notes },
      { href: `${base}/tags/`, label: ui.tags.title },
    ].map((link) => (
      <a
        href={link.href}
        class="text-xs px-3 py-1.5 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-muted)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
      >
        {link.label}
      </a>
    ))
  }
</nav>

<div class="mb-4">
  <p class="text-xs text-[var(--color-muted)] mb-2">{ui.search.tryLabel}</p>
  <div class="flex flex-wrap gap-2">
    {
      quickTerms.map((term) => (
        <button
          type="button"
          class="search-quick-term text-xs px-3 py-1 rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] hover:bg-[var(--color-primary)]/15 transition-colors"
          data-term={term}
        >
          {term}
        </button>
      ))
    }
  </div>
</div>

<div class="mb-5">
  <p class="text-xs text-[var(--color-muted)] mb-2">{ui.search.typeFilterLabel}</p>
  <div class="flex flex-wrap gap-2" role="group" aria-label={ui.search.typeFilterLabel}>
    {
      typeFilters.map((item, index) => (
        <button
          type="button"
          class:list={[
            'search-type-filter text-xs px-3 py-1.5 rounded-full border transition-colors',
            index === 0
              ? 'border-[var(--color-primary)] bg-[var(--color-primary)]/10 text-[var(--color-primary)]'
              : 'border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-muted)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]',
          ]}
          data-type={item.key}
          aria-pressed={index === 0 ? 'true' : 'false'}
        >
          {item.label}
        </button>
      ))
    }
  </div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<div id="search" class="pagefind-search"></div>

<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline define:vars={{ pagefindLang, placeholder: ui.search.placeholder, emptyText: ui.search.empty }}>
  const typePatterns = {
    blog: '/blog/',
    project: '/projects/',
    note: '/notes/',
  };

  let activeType = '';
  let typeObserver = null;

  function applyTypeFilter(root, type) {
    activeType = type;
    const pattern = typePatterns[type];
    root.querySelectorAll('.pagefind-ui__result').forEach((result) => {
      if (!pattern) {
        result.style.display = '';
        return;
      }
      const href = result.querySelector('a')?.getAttribute('href') ?? '';
      result.style.display = href.includes(pattern) ? '' : 'none';
    });
  }

  function bindTypeFilters(root) {
    document.querySelectorAll('.search-type-filter').forEach((btn) => {
      if (btn.dataset.bound === 'true') return;
      btn.dataset.bound = 'true';
      btn.addEventListener('click', () => {
        document.querySelectorAll('.search-type-filter').forEach((peer) => {
          const selected = peer === btn;
          peer.setAttribute('aria-pressed', selected ? 'true' : 'false');
          peer.classList.toggle('border-[var(--color-primary)]', selected);
          peer.classList.toggle('bg-[var(--color-primary)]/10', selected);
          peer.classList.toggle('text-[var(--color-primary)]', selected);
          peer.classList.toggle('border-[var(--color-border)]', !selected);
          peer.classList.toggle('bg-[var(--color-surface)]', !selected);
          peer.classList.toggle('text-[var(--color-muted)]', !selected);
        });
        applyTypeFilter(root, btn.dataset.type ?? '');
      });
    });
  }

  function watchResults(root) {
    typeObserver?.disconnect();
    const results = root.querySelector('.pagefind-ui__results');
    if (!results) return;
    typeObserver = new MutationObserver(() => applyTypeFilter(root, activeType));
    typeObserver.observe(results, { childList: true, subtree: true });
  }

  function hideLanguageFilter(root) {
    root.querySelectorAll('.pagefind-ui__filter-block').forEach((block) => {
      const name = block.querySelector('.pagefind-ui__filter-name')?.textContent?.toLowerCase() ?? '';
      if (name.includes('language')) block.remove();
    });
    const panel = root.querySelector('.pagefind-ui__filter-panel');
    if (panel && panel.querySelectorAll('.pagefind-ui__filter-block').length === 0) {
      panel.remove();
    }
  }

  function initSearch() {
    if (typeof PagefindUI === 'undefined') return;
    const el = document.getElementById('search');
    if (!el) return;
    el.innerHTML = '';
    typeObserver?.disconnect();
    activeType = '';

    new PagefindUI({
      element: '#search',
      bundlePath: '/pagefind/',
      showSubResults: true,
      excludeFilters: ['language'],
      filters: { language: pagefindLang },
      translations: {
        placeholder,
        zero_results: emptyText,
      },
    });

    window.setTimeout(() => {
      hideLanguageFilter(el);
      watchResults(el);
      bindTypeFilters(el);

      const input = el.querySelector('.pagefind-ui__search-input');
      if (!(input instanceof HTMLInputElement)) return;

      const params = new URLSearchParams(window.location.search);
      const q = params.get('q');
      if (q) {
        input.value = q;
        input.dispatchEvent(new Event('input', { bubbles: true }));
      } else {
        input.focus();
      }

      document.querySelectorAll('.search-quick-term').forEach((btn) => {
        if (btn.dataset.bound === 'true') return;
        btn.dataset.bound = 'true';
        btn.addEventListener('click', () => {
          const term = btn.dataset.term ?? '';
          input.value = term;
          input.dispatchEvent(new Event('input', { bubbles: true }));
          input.focus();
        });
      });
    }, 80);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
  document.addEventListener('astro:after-swap', initSearch);
</script>

<style is:global>
  .pagefind-search {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-primary);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-bg);
    --pagefind-ui-font: var(--font-sans);
  }

  .pagefind-search .pagefind-ui__filter-panel {
    display: none !important;
  }

  .pagefind-search .pagefind-ui__form {
    margin-bottom: 1.25rem;
  }

  .pagefind-search .pagefind-ui__search-input {
    border-radius: 0.75rem;
    padding: 0.875rem 1rem 0.875rem 2.75rem;
    font-size: 1rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    height: auto;
  }

  .pagefind-search .pagefind-ui__search-input:focus {
    outline: 2px solid color-mix(in srgb, var(--color-primary) 35%, transparent);
    outline-offset: 0;
    border-color: var(--color-primary);
  }

  .pagefind-search .pagefind-ui__result {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem 1.125rem;
    margin-bottom: 0.75rem;
    background: var(--color-surface);
    transition: border-color 0.2s;
    border-top: 1px solid var(--color-border);
  }

  .pagefind-search .pagefind-ui__result:hover {
    border-color: color-mix(in srgb, var(--color-primary) 45%, var(--color-border));
  }

  .pagefind-search .pagefind-ui__result-title {
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.4;
  }

  .pagefind-search .pagefind-ui__result-excerpt {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin-top: 0.375rem;
    min-width: 0;
  }

  .pagefind-search .pagefind-ui__result-tags {
    margin-top: 0.625rem;
    gap: 0.375rem;
  }

  .pagefind-search .pagefind-ui__result-tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: var(--color-bg);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
  }

  .pagefind-search mark {
    background: color-mix(in srgb, var(--color-primary) 22%, transparent);
    color: inherit;
    border-radius: 0.125rem;
    padding: 0 0.125rem;
  }

  .pagefind-search .pagefind-ui__message {
    color: var(--color-muted);
    font-size: 0.875rem;
    padding: 2rem 0;
    text-align: center;
    font-weight: 500;
  }
</style>
