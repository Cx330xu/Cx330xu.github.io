---
import type { Locale } from '../i18n/ui';

interface Props {
  tags: string[];
  locale: Locale;
}

const { tags, locale } = Astro.props;
---

{
  tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <a
          href={`/${locale}/tags/${tag.toLowerCase()}/`}
          class="text-sm px-3 py-1 rounded-full border border-[var(--color-border)] text-[var(--color-muted)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
        >
          #{tag}
        </a>
      ))}
    </div>
  )
}
