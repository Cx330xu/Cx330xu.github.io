---
import type { Locale } from '../i18n/ui';
import Chip from './Chip.astro';

interface Props {
  tags: string[];
  locale: Locale;
}

const { tags, locale } = Astro.props;
---

{
  tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <Chip label={tag} href={`/${locale}/tags/${tag.toLowerCase()}/`} variant="primary" />
      ))}
    </div>
  )
}
