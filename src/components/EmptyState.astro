---
import { profile } from '../data/site';
import { t, type Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  message: string;
  hint?: string;
}

const { locale, message, hint } = Astro.props;
const ui = t(locale);
---

<div class="rounded-xl border border-dashed border-[var(--color-border)] bg-[var(--color-surface)] px-6 py-10 text-center">
  <p class="text-[var(--color-text)] font-medium mb-2">{message}</p>
  {hint && <p class="text-sm text-[var(--color-muted)] mb-6">{hint}</p>}
  <div class="flex flex-wrap justify-center gap-3">
    <a
      href={`/${locale}/about/`}
      class="px-4 py-2 text-sm rounded-lg border border-[var(--color-border)] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
    >
      {ui.empty.viewAbout}
    </a>
    <a
      href={profile.github}
      target="_blank"
      rel="noopener noreferrer"
      class="px-4 py-2 text-sm rounded-lg bg-[var(--color-primary)] text-white hover:opacity-90 transition-opacity"
    >
      {ui.empty.viewGithub}
    </a>
  </div>
</div>
