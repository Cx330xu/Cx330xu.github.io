---
import { getSlugFromId, formatDate } from '../utils/content';
import type { Locale } from '../i18n/ui';
import type { CollectionEntry } from 'astro:content';
import { t } from '../i18n/ui';

interface Props {
  project: CollectionEntry<'projects'>;
  locale: Locale;
}

const { project, locale } = Astro.props;
const ui = t(locale);
const slug = getSlugFromId(project.id);
---

<article class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 hover:border-[var(--color-primary)] transition-colors">
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="font-semibold text-lg group-hover:text-[var(--color-primary)] transition-colors">
      <a href={`/${locale}/projects/${slug}/`}>{project.data.title}</a>
    </h3>
    <span class="text-xs px-2 py-0.5 rounded-full bg-[var(--color-bg)] text-[var(--color-muted)] shrink-0">
      {ui.projects.status[project.data.status]}
    </span>
  </div>
  <p class="text-sm text-[var(--color-muted)] mb-3 line-clamp-2">{project.data.description}</p>
  {
    project.data.stack.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {project.data.stack.map((s) => (
          <span class="text-xs px-2 py-0.5 rounded-md bg-[var(--color-bg)] text-[var(--color-muted)] border border-[var(--color-border)]">
            {s}
          </span>
        ))}
      </div>
    )
  }
  <div class="flex items-center gap-3 text-sm">
    <a
      href={project.data.github}
      target="_blank"
      rel="noopener noreferrer"
      class="text-[var(--color-primary)] hover:underline"
    >
      {ui.projects.github} →
    </a>
    <span class="text-xs text-[var(--color-muted)]">{formatDate(project.data.date, locale)}</span>
  </div>
</article>
