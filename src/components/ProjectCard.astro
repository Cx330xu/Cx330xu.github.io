---
import { getSlugFromId, formatDate, getInitials } from '../utils/content';
import type { Locale } from '../i18n/ui';
import type { CollectionEntry } from 'astro:content';
import { t } from '../i18n/ui';
import Chip from './Chip.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  locale: Locale;
  starCount?: number;
}

const { project, locale, starCount } = Astro.props;
const ui = t(locale);
const slug = getSlugFromId(project.id);
const initials = getInitials(project.data.title);
const isActive = project.data.status === 'active';
const hasDemo = Boolean(project.data.demo);
---

<article class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 card-hover">
  <div class="flex gap-4">
    {
      project.data.cover ? (
        <div class="shrink-0 w-16 h-16 rounded-lg overflow-hidden border border-[var(--color-border)]">
          <img
            src={project.data.cover}
            alt={project.data.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="shrink-0 w-11 h-11 rounded-lg bg-[var(--color-primary)]/10 text-[var(--color-primary)] font-bold text-sm flex items-center justify-center border border-[var(--color-primary)]/20">
          {initials}
        </div>
      )
    }
    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-3 mb-2">
        <h3 class="font-semibold text-lg group-hover:text-[var(--color-primary)] transition-colors">
          <a href={`/${locale}/projects/${slug}/`}>{project.data.title}</a>
        </h3>
        <span class="inline-flex items-center gap-1.5 text-xs px-2 py-0.5 rounded-full bg-[var(--color-bg)] text-[var(--color-muted)] shrink-0">
          {isActive && <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-success)]" />}
          {ui.projects.status[project.data.status]}
        </span>
      </div>
      <p class="text-sm text-[var(--color-muted)] mb-3 line-clamp-2">{project.data.description}</p>
      {
        project.data.stack.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mb-3">
            {project.data.stack.map((s) => (
              <Chip label={s} prefixHash={false} />
            ))}
          </div>
        )
      }
      <div class="flex flex-wrap items-center gap-3 text-sm">
        <a
          href={project.data.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-[var(--color-primary)] hover:underline"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          {ui.projects.github}
          {
            starCount !== undefined && starCount > 0 && (
              <span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded-full bg-[var(--color-primary)]/10 text-xs font-semibold">
                ⭐ {starCount}
              </span>
            )
          }
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
        {
          hasDemo && (
            <a
              href={project.data.demo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 text-[var(--color-muted)] hover:text-[var(--color-primary)] hover:underline"
            >
              {ui.projects.demo}
            </a>
          )
        }
        <span class="text-xs text-[var(--color-muted)]">
          {ui.projects.lastUpdated}: {formatDate(project.data.date, locale)}
        </span>
      </div>
    </div>
  </div>
</article>
