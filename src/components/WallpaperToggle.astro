---
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  /** icon: icon-only for Header; compact: icon+label for HeroAside; full: label+switch for mobile */
  variant?: 'icon' | 'compact' | 'full';
}

const { locale, variant = 'compact' } = Astro.props;

const labels = locale === 'zh'
  ? { clean: '壁纸', gallery: '映像', hint: '切换壁纸模式 | 双击换一张', refresh: '换一张', tip: '点击切换简洁模式 · 双击换壁纸' }
  : { clean: 'WP', gallery: 'Gallery', hint: 'Toggle wallpaper | Double-click to cycle', refresh: 'Refresh', tip: 'Click for clean · Double-click to cycle' };
---

<button
  type="button"
  class="wallpaper-toggle group inline-flex items-center gap-2 text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors cursor-pointer bg-transparent border-0 p-0"
  data-variant={variant}
  data-label-clean={labels.clean}
  data-label-gallery={labels.gallery}
  data-label-refresh={labels.refresh}
  data-label-tip={labels.tip}
  title={labels.hint}
  aria-label={labels.hint}
>
  <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
  </svg>
  {
    variant !== 'icon' && (
      <span class="wallpaper-mode-label">{labels.clean}</span>
    )
  }
  {
    variant === 'full' && (
      <span class="inline-flex items-center px-1.5 h-5 rounded-full bg-[var(--color-border)] transition-colors group-hover:bg-[var(--color-primary)]/30" aria-hidden="true">
        <span class="wallpaper-switch-dot w-3 h-3 rounded-full bg-white shadow-sm transition-transform"></span>
      </span>
    )
  }
</button>

{/* Refresh button: shown next to toggle when wallpaper is active */}
<button
  type="button"
  class="wallpaper-refresh-btn hidden ml-1 p-1 rounded text-[var(--color-muted)]/40 hover:text-[var(--color-primary)] transition-colors cursor-pointer bg-transparent border-0"
  title={labels.refresh}
  aria-label={labels.refresh}
>
  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
  </svg>
</button>

{/* Hint text (full variant only, shown below the controls) */}
{
  variant === 'full' && (
    <span class="wallpaper-hint text-[11px] text-[var(--color-muted)]/50 ml-1 hidden" aria-live="polite"></span>
  )
}

<script>
  function initToggle() {
    document.querySelectorAll('.wallpaper-toggle:not([data-bound])').forEach((btn) => {
      btn.dataset.bound = 'true';
      const variant = btn.dataset.variant;
      const labelClean = btn.dataset.labelClean ?? 'Clean';
      const labelGallery = btn.dataset.labelGallery ?? 'Gallery';
      const labelTip = btn.dataset.labelTip ?? '';

      // Find sibling refresh button and hint (next to the toggle btn)
      const refreshBtn = btn.nextElementSibling?.classList.contains('wallpaper-refresh-btn')
        ? (btn.nextElementSibling as HTMLElement)
        : null;
      const hint = refreshBtn?.nextElementSibling?.classList.contains('wallpaper-hint')
        ? (refreshBtn.nextElementSibling as HTMLElement)
        : null;

      let doubleClickTimer: ReturnType<typeof setTimeout> | null = null;

      function updateUI(active: boolean) {
        const label = btn.querySelector('.wallpaper-mode-label');
        if (label) label.textContent = active ? labelGallery : labelClean;
        if (variant === 'full') {
          const dot = btn.querySelector('.wallpaper-switch-dot') as HTMLElement;
          if (dot) dot.style.transform = active ? 'translateX(8px)' : 'translateX(0)';
        }
        btn.classList.toggle('text-[var(--color-primary)]', active);
        // Show refresh button only when gallery mode is active
        if (refreshBtn) refreshBtn.classList.toggle('hidden', !active);
        if (hint) {
          hint.textContent = active ? labelTip : '';
          hint.classList.toggle('hidden', !active);
        }
      }

      // Check wallpaper count — hide refresh if only 1
      const count = typeof (window as any).__wallpaperCount === 'function'
        ? (window as any).__wallpaperCount()
        : 0;
      if (refreshBtn && count <= 1) refreshBtn.classList.add('!hidden');

      // Init state — default to gallery
      const stored = localStorage.getItem('wallpaper-mode');
      let active = stored !== 'clean';
      updateUI(active);

      // ── Click: toggle on/off ──
      btn.addEventListener('click', () => {
        // Detect double-click for cycling
        if (doubleClickTimer) {
          clearTimeout(doubleClickTimer);
          doubleClickTimer = null;
          // Double-click: cycle wallpaper (only when active)
          if (active) {
            window.dispatchEvent(new CustomEvent('wallpaper-cycle'));
          }
          return;
        }
        doubleClickTimer = setTimeout(() => { doubleClickTimer = null; }, 300);

        // Single click: toggle
        active = !active;
        localStorage.setItem('wallpaper-mode', active ? 'gallery' : 'clean');
        updateUI(active);
        window.dispatchEvent(new CustomEvent('wallpaper-change', { detail: { active } }));
      });

      // ── Refresh button: fetch fresh from Bing ──
      if (refreshBtn) {
        refreshBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          window.dispatchEvent(new CustomEvent('wallpaper-refresh'));
        });
      }
    });
  }
  initToggle();
  document.addEventListener('astro:after-swap', initToggle);
</script>
