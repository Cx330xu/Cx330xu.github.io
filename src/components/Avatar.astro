---
import { profile } from '../data/site';
---

<div class="relative shrink-0">
  <img
    src={profile.avatar}
    alt={profile.name}
    width="80"
    height="80"
    class="w-20 h-20 rounded-full border-2 border-[var(--color-border)] bg-[var(--color-surface)] object-cover"
    onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
  />
  <div
    class="w-20 h-20 rounded-full border-2 border-[var(--color-border)] bg-[var(--color-primary)] text-white items-center justify-center text-2xl font-bold hidden"
    aria-hidden="true"
  >
    C
  </div>
</div>
