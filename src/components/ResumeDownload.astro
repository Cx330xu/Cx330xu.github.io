---
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  variant?: 'button' | 'inline';
}

const { locale, variant = 'button' } = Astro.props;

const label = locale === 'zh' ? '下载简历' : 'Download Resume';
const desc = locale === 'zh'
  ? 'PDF 格式，含完整项目经验与技术栈'
  : 'PDF format — projects, stack & experience';

const href = '/resume.pdf';

const isButton = variant === 'button';
---

{
  isButton ? (
    <a
      href={href}
      download
      class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-sm font-medium hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
      title={desc}
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      {label}
    </a>
  ) : (
    <a
      href={href}
      download
      class="text-[var(--color-primary)] hover:underline inline-flex items-center gap-1 text-sm"
      title={desc}
    >
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      {label}
    </a>
  )
}
