---
import { profile } from '../data/site';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  variant?: 'button' | 'inline';
}

const { locale, variant = 'button' } = Astro.props;

const label = locale === 'zh' ? '索取简历' : 'Request Resume';
const desc = locale === 'zh'
  ? '为保护隐私，简历不公开下载。请通过邮件联系，我会根据岗位定向发送。'
  : 'For privacy, resume is not publicly downloadable. Email me and I\'ll share a tailored version.';

const subject = locale === 'zh' ? '[简历请求]' : '[Resume Request]';
const href = `mailto:${profile.email}?subject=${encodeURIComponent(subject)} ${profile.name}`;

const isButton = variant === 'button';
---

{
  isButton ? (
    <a
      href={href}
      class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-sm font-medium hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
      title={desc}
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      {label}
    </a>
  ) : (
    <a
      href={href}
      class="text-[var(--color-primary)] hover:underline inline-flex items-center gap-1 text-sm"
      title={desc}
    >
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      {label}
    </a>
  )
}
