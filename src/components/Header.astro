---
import { profile } from '../data/site';
import { t, type Locale } from '../i18n/ui';
import LangSwitch from './LangSwitch.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const ui = t(locale);
const base = `/${locale}`;

const links = [
  { href: `${base}/projects/`, label: ui.nav.projects },
  { href: `${base}/blog/`, label: ui.nav.blog },
  { href: `${base}/notes/`, label: ui.nav.notes },
  { href: `${base}/about/`, label: ui.nav.about },
];

function isActive(href: string) {
  return currentPath.startsWith(href);
}

function isHome(path: string) {
  return path === `${base}/` || path === base;
}
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur-md">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between gap-4">
    <a
      href={`/${locale}/`}
      class:list={[
        'font-semibold transition-colors shrink-0',
        isHome(currentPath) ? 'text-[var(--color-primary)]' : 'text-[var(--color-text)] hover:text-[var(--color-primary)]',
      ]}
    >
      {profile.name}
    </a>

    <nav class="hidden md:flex items-center gap-1 text-sm">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-1.5 rounded-md transition-colors',
              isActive(link.href)
                ? 'text-[var(--color-primary)] bg-[var(--color-surface)] font-medium'
                : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <a
        href={`/${locale}/search/`}
        class="p-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors"
        title={ui.nav.search}
        aria-label={ui.nav.search}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>
      <a
        href={`/${locale}/rss.xml`}
        class="hidden sm:inline text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)]"
        title={ui.rss}
      >
        RSS
      </a>
      <LangSwitch locale={locale} currentPath={currentPath} />
      <ThemeToggle locale={locale} />
    </div>
  </div>

  <nav class="md:hidden flex overflow-x-auto gap-1 px-4 pb-2 text-sm border-t border-[var(--color-border)]">
    {
      links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-1.5 rounded-md whitespace-nowrap shrink-0',
            isActive(link.href) ? 'text-[var(--color-primary)] font-medium' : 'text-[var(--color-muted)]',
          ]}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
