---
import { profile } from '../data/site';
import { t, type Locale } from '../i18n/ui';
import LangSwitch from './LangSwitch.astro';
import ThemeToggle from './ThemeToggle.astro';
import WallpaperToggle from './WallpaperToggle.astro';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const ui = t(locale);
const base = `/${locale}`;

const links = [
  { href: `${base}/projects/`, label: ui.nav.projects },
  { href: `${base}/blog/`, label: ui.nav.blog },
  { href: `${base}/notes/`, label: ui.nav.notes },
  { href: `${base}/about/`, label: ui.nav.about },
];

function isActive(href: string) {
  return currentPath.startsWith(href);
}

function isHome(path: string) {
  return path === `${base}/` || path === base;
}
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur-md">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between gap-4">
    <a
      href={`/${locale}/`}
      class:list={[
        'inline-flex items-center gap-2 font-semibold transition-colors shrink-0 py-1 pr-1 -ml-1 rounded-md',
        isHome(currentPath) ? 'text-[var(--color-primary)]' : 'text-[var(--color-text)] hover:text-[var(--color-primary)]',
      ]}
      aria-label={ui.nav.home}
    >
      <img src="/favicon.svg" alt="" width="22" height="22" class="rounded-md shrink-0" aria-hidden="true" />
      {profile.name}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1 text-sm">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-1.5 rounded-md transition-colors',
              isActive(link.href)
                ? 'text-[var(--color-primary)] bg-[var(--color-surface)] font-medium'
                : 'text-[var(--color-muted)] hover:text-[var(--color-text)]',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 shrink-0">
      <a
        href={`/${locale}/search/`}
        class="p-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors"
        title={ui.nav.searchShortcut}
        aria-label={ui.nav.searchShortcut}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>
      <a
        href={`/${locale}/rss.xml`}
        class="p-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors"
        title={ui.rss}
        aria-label={ui.rss}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7M6 17h.01M6 5v6" />
        </svg>
      </a>
      <LangSwitch locale={locale} currentPath={currentPath} />
      <ThemeToggle locale={locale} />
      <WallpaperToggle locale={locale} variant="icon" />
      <!-- Hamburger button (mobile only) -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden p-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
        aria-label={locale === 'zh' ? '打开菜单' : 'Open menu'}
        aria-expanded="false"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer overlay -->
  <div id="mobile-drawer-overlay" class="fixed inset-0 bg-black/40 z-40 hidden md:hidden" aria-hidden="true"></div>
  <!-- Mobile drawer -->
  <nav
    id="mobile-drawer"
    class="fixed top-0 right-0 h-full w-64 max-w-[80vw] bg-[var(--color-bg)] border-l border-[var(--color-border)] z-50 shadow-2xl translate-x-full transition-transform duration-300 ease-in-out md:hidden"
    aria-label={locale === 'zh' ? '移动端导航' : 'Mobile navigation'}
  >
    <div class="flex items-center justify-between px-4 h-14 border-b border-[var(--color-border)]">
      <span class="font-semibold text-sm text-[var(--color-muted)]">
        {locale === 'zh' ? '导航' : 'Menu'}
      </span>
      <button
        id="mobile-drawer-close"
        type="button"
        class="p-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
        aria-label={locale === 'zh' ? '关闭菜单' : 'Close menu'}
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="flex flex-col p-4 gap-1">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2.5 rounded-lg text-base transition-colors',
              isActive(link.href)
                ? 'text-[var(--color-primary)] bg-[var(--color-surface)] font-medium'
                : 'text-[var(--color-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  function setupMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const drawer = document.getElementById('mobile-drawer');
    const overlay = document.getElementById('mobile-drawer-overlay');
    const closeBtn = document.getElementById('mobile-drawer-close');
    if (!btn || !drawer || !overlay || !closeBtn) return;

    function open() {
      drawer.classList.remove('translate-x-full');
      overlay.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }

    function close() {
      drawer.classList.add('translate-x-full');
      overlay.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      btn.focus();
    }

    btn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !drawer.classList.contains('translate-x-full')) {
        close();
      }
    });

    // Close on nav link click
    drawer.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        setTimeout(close, 100);
      });
    });
  }

  setupMobileMenu();
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>
