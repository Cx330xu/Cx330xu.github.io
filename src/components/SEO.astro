---
import { profile } from '../data/site';

interface Props {
  title: string;
  description?: string;
  locale: 'zh' | 'en';
  image?: string;
}

const { title, description = 'Cx330xu · AI Agent Engineer — LLM, RAG, Agent, Open Source', locale, image } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const rssPath = locale === 'zh' ? '/zh/rss.xml' : '/en/rss.xml';
const ogImagePath = image ?? profile.ogImage;
const ogImage = new URL(ogImagePath, Astro.site ?? 'https://Cx330xu.github.io');
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonical} />
<link rel="alternate" type="application/rss+xml" title="RSS" href={rssPath} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
  rel="stylesheet"
/>
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
